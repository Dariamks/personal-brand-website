{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost:4321/",
        "http://localhost:4321/blog/2025-01-15-hello-world/"
      ]
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "performance": ["error", { "minScore": 0.9 }],
            "seo": ["error", { "minScore": 0.9 }],
            "accessibility": ["error", { "minScore": 0.9 }],
            "best-practices": ["error", { "minScore": 0.9 }]
          }
        }
      ]
    }
  }
}
