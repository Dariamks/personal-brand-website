{
  "name": "personal-brand-website",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "validate-content": "tsx scripts/validate-content.ts",
    "pagefind": "pagefind --site dist",
    "prebuild": "pnpm validate-content || true",
    "postbuild": "pnpm pagefind || true",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.5",
    "@fontsource-variable/jetbrains-mono": "^5.2.5"
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.2.4",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.6.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "astro": "^5.15.0",
    "fast-check": "^4.8.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-mdx": "^3.0.0",
    "pagefind": "^1.3.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-smartypants": "^3.0.0",
    "sharp": "^0.34.1",
    "tailwindcss": "^4.1.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.0.6",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
