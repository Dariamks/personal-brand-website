---
interface Props {
  title: string;
  date: string;
  category: string;
  tags: string[];
  summary: string;
  slug: string;
}

const { title, date, category, tags, summary, slug } = Astro.props;
const truncatedSummary = summary.length > 150 ? summary.slice(0, 150) + "..." : summary;
const displayTags = tags.slice(0, 5);
---

<article class="group border border-[var(--color-border)] rounded-xl p-5 bg-[var(--color-bg)] hover:shadow-md transition-shadow duration-200">
  <!-- Date & Category -->
  <div class="flex items-center gap-3 mb-2">
    <time datetime={date} class="text-xs text-[var(--color-fg-muted)] font-mono">
      {date.slice(0, 10)}
    </time>
    <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-[var(--color-code-bg)] text-[var(--color-fg-muted)] border border-[var(--color-border)]">
      {category}
    </span>
  </div>

  <!-- Title -->
  <a href={`/blog/${slug}`} class="no-underline">
    <h3 class="text-lg font-semibold text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-200 mb-2">
      {title}
    </h3>
  </a>

  <!-- Summary -->
  <p class="text-sm text-[var(--color-fg-muted)] mb-3 leading-relaxed">
    {truncatedSummary}
  </p>

  <!-- Tags -->
  {displayTags.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {displayTags.map((tag) => (
        <span class="inline-block px-2 py-0.5 text-xs rounded-full bg-[var(--color-code-bg)] text-[var(--color-fg-muted)] border border-[var(--color-border)]">
          #{tag}
        </span>
      ))}
    </div>
  )}

  <!-- Read more -->
  <div class="mt-3 pt-3 border-t border-[var(--color-border)]">
    <a
      href={`/blog/${slug}`}
      class="text-sm text-[var(--color-accent)] hover:underline no-underline transition-colors duration-200"
    >
      阅读全文 &rarr;
    </a>
  </div>
</article>
