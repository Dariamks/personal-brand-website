---
import { getCollection } from "astro:content";

interface SocialLink {
  label: string;
  url: string;
  icon: "github" | "linkedin" | "twitter" | "email";
}

interface SiteData {
  name?: string;
  tagline?: string;
  email?: string;
  social?: {
    github?: string;
    linkedin?: string;
    twitter?: string;
  };
}

let site: SiteData = {};
try {
  const siteEntries = await getCollection("site");
  if (siteEntries.length > 0) {
    site = siteEntries[0].data as SiteData;
  }
} catch {
  // Fallback if content config doesn't exist yet
}

const brandName: string = site.name || "NAME.";
const tagline: string = site.tagline || "";
const email: string = site.email || "";

const socialLinks: SocialLink[] = [];
if (site.social?.github) {
  socialLinks.push({ label: "GitHub", url: site.social.github, icon: "github" });
}
if (site.social?.linkedin) {
  socialLinks.push({ label: "LinkedIn", url: site.social.linkedin, icon: "linkedin" });
}
if (site.social?.twitter) {
  socialLinks.push({ label: "Twitter", url: site.social.twitter, icon: "twitter" });
}

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-20">
  <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <p class="text-lg font-semibold text-[var(--color-fg)]">{brandName}</p>
        {tagline && (
          <p class="mt-1 text-sm text-[var(--color-fg-muted)]">{tagline}</p>
        )}
      </div>

      <!-- Contact & Social -->
      <div>
        <p class="text-sm font-medium text-[var(--color-fg)] mb-3">联系</p>
        <div class="flex flex-col gap-2">
          {email && (
            <a
              href={`mailto:${email}`}
              id="email-link"
              class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 no-underline"
            >
              {email}
            </a>
          )}
          <div class="flex gap-3 mt-1">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener"
                aria-label={link.label}
                class="text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors duration-200"
              >
                {link.icon === "github" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="w-5 h-5"
                    aria-hidden="true"
                  >
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                  </svg>
                )}
                {link.icon === "linkedin" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="w-5 h-5"
                    aria-hidden="true"
                  >
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                )}
                {link.icon === "twitter" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="w-5 h-5"
                    aria-hidden="true"
                  >
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                  </svg>
                )}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Links -->
      <div>
        <p class="text-sm font-medium text-[var(--color-fg)] mb-3">订阅与链接</p>
        <div class="flex flex-col gap-2">
          <a
            href="/feed.xml"
            class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 no-underline"
          >
            Blog RSS
          </a>
          <a
            href="/journal/feed.xml"
            class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 no-underline"
          >
            Journal RSS
          </a>
          <a
            href="/sitemap-index.xml"
            class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 no-underline"
          >
            网站地图
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-[var(--color-border)]">
      <p class="text-xs text-[var(--color-fg-muted)]">
        &copy; {currentYear} {brandName}. All rights reserved.
      </p>
    </div>
  </div>

  <!-- Email toast container -->
  <div
    id="email-toast"
    class="fixed bottom-6 right-6 px-4 py-2 bg-[var(--color-fg)] text-[var(--color-bg)] text-sm rounded-lg shadow-lg opacity-0 translate-y-2 pointer-events-none transition-all duration-200 z-50"
    role="status"
    aria-live="polite"
  >
    邮箱地址已复制到剪贴板
  </div>
</footer>

<script is:inline>
  (function () {
    const emailLink = document.getElementById("email-link");
    const toast = document.getElementById("email-toast");
    if (!emailLink || !toast) return;

    let toastTimer = null;

    function showToast() {
      if (toastTimer) clearTimeout(toastTimer);
      toast.classList.remove("opacity-0", "translate-y-2", "pointer-events-none");
      toast.classList.add("opacity-100", "translate-y-0");
      toastTimer = setTimeout(() => {
        toast.classList.add("opacity-0", "translate-y-2");
        toast.classList.remove("opacity-100", "translate-y-0");
      }, 2000);
    }

    emailLink.addEventListener("click", (e) => {
      // Wait 500ms; if visibilitychange didn't fire, mail client didn't open
      let mailOpened = false;
      const onVisibility = () => {
        mailOpened = true;
        document.removeEventListener("visibilitychange", onVisibility);
      };
      document.addEventListener("visibilitychange", onVisibility);

      setTimeout(() => {
        document.removeEventListener("visibilitychange", onVisibility);
        if (!mailOpened) {
          // Copy email to clipboard
          const addr = emailLink.getAttribute("href")?.replace("mailto:", "") || "";
          if (addr) {
            navigator.clipboard.writeText(addr).catch(() => {});
          }
          showToast();
        }
      }, 500);
    });
  })();
</script>
