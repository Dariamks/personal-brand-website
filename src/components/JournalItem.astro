---
interface Props {
  date: string;
  body: string;
  tags?: string[];
  slug: string;
}

const { date, body, tags = [], slug } = Astro.props;
const isLong = body.length > 120;
const truncated = isLong ? body.slice(0, 120) + "..." : body;
---

<article class="border-b border-[var(--color-border)] py-5 last:border-b-0">
  <div class="flex items-center gap-3 mb-2">
    <time
      datetime={date}
      class="text-xs text-[var(--color-fg-muted)] font-mono"
    >
      {date.slice(0, 10)}
    </time>

    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1">
          {tags.map((tag) => (
            <span class="inline-block px-1.5 py-0.5 text-xs rounded bg-[var(--color-code-bg)] text-[var(--color-fg-muted)]">
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </div>

  {
    isLong ? (
      <details class="group/details">
        <summary class="list-none cursor-pointer marker:hidden">
          {/* 折叠态：截断正文 + "展开全文" */}
          <span class="group-open/details:hidden text-sm text-[var(--color-fg-muted)] leading-relaxed">
            {truncated}
            <span class="ml-1 whitespace-nowrap text-[var(--color-accent)] text-xs">
              展开全文
            </span>
          </span>
          {/* 展开态：仅"收起" */}
          <span class="hidden group-open/details:inline-block text-[var(--color-accent)] text-xs">
            收起
          </span>
        </summary>
        {/* 展开态：完整正文 */}
        <p class="mt-2 text-sm text-[var(--color-fg-muted)] leading-relaxed whitespace-pre-line">
          {body}
        </p>
      </details>
    ) : (
      <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed whitespace-pre-line">
        {body}
      </p>
    )
  }

  <a
    href={`/journal/${slug}`}
    class="inline-block mt-2 text-xs text-[var(--color-accent)] hover:underline no-underline transition-colors duration-200"
  >
    查看详情 &rarr;
  </a>
</article>
