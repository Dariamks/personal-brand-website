---
import { Image } from "astro:assets";

interface Props {
  title: string;
  summary: string;
  stack: string[];
  slug: string;
  cover?: { src: string; width: number; height: number; format: string } | null;
  demo?: string;
  repo?: string;
}

const { title, summary, stack, slug, cover, demo, repo } = Astro.props;
const displayStack = stack.slice(0, 6);
const truncatedSummary = summary.length > 120 ? summary.slice(0, 120) + "..." : summary;
---

<article class="group border border-[var(--color-border)] rounded-xl overflow-hidden bg-[var(--color-bg)] hover:shadow-md transition-shadow duration-200">
  <a href={`/projects/${slug}`} class="no-underline">
    <!-- Cover image -->
    <div class="aspect-video bg-[var(--color-code-bg)] overflow-hidden">
      {cover ? (
        <Image
          src={cover}
          alt={`${title} 封面`}
          widths={[320, 640, 960]}
          formats={["avif", "webp"]}
          loading="lazy"
          decoding="async"
          class="w-full aspect-video object-cover rounded-lg transition-transform duration-200 group-hover:scale-105"
        />
      ) : (
        <div class="w-full aspect-video bg-[var(--color-code-bg)] rounded-lg flex items-center justify-center text-[var(--color-fg-muted)] text-sm">
          暂无封面
        </div>
      )}
    </div>
  </a>

  <div class="p-5">
    <!-- Title -->
    <a href={`/projects/${slug}`} class="no-underline">
      <h3 class="text-lg font-semibold text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-200 mb-2">
        {title}
      </h3>
    </a>

    <!-- Summary -->
    <p class="text-sm text-[var(--color-fg-muted)] mb-3 leading-relaxed">
      {truncatedSummary}
    </p>

    <!-- Stack tags -->
    {displayStack.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {displayStack.map((tech) => (
          <span class="inline-block px-2 py-0.5 text-xs rounded-full bg-[var(--color-code-bg)] text-[var(--color-fg-muted)] border border-[var(--color-border)]">
            {tech}
          </span>
        ))}
      </div>
    )}

    <!-- Action links -->
    {(demo || repo) && (
      <div class="flex gap-4 pt-2 border-t border-[var(--color-border)]">
        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener"
            class="text-sm text-[var(--color-accent)] hover:underline no-underline transition-colors duration-200"
          >
            Demo &rarr;
          </a>
        )}
        {repo && (
          <a
            href={repo}
            target="_blank"
            rel="noopener"
            class="text-sm text-[var(--color-accent)] hover:underline no-underline transition-colors duration-200"
          >
            Repo &rarr;
          </a>
        )}
      </div>
    )}
  </div>
</article>
