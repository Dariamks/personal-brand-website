---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", (p) => !p.data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((cat) => ({
    params: { category: cat },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

const allPosts = await getCollection("blog", (p) => !p.data.draft);
const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

// All categories for the filter pills
const categories = [...new Set(allPosts.map((p) => p.data.category))].sort();
const tags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();

function truncate(s: string, max = 150): string {
  return s.length > max ? s.slice(0, max) + "..." : s;
}
---

<BaseLayout
  title={`分类: ${category}`}
  description={`${category} 相关的文章`}
>
  <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-medium text-[var(--color-fg)] mb-2">
      分类: {category}
    </h1>
    <a
      href="/blog"
      class="inline-block text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] no-underline transition-colors duration-200 mb-8"
    >
      &larr; 全部文章
    </a>

    <!-- Category filters -->
    <div class="flex flex-wrap gap-2 mb-4">
      <a
        href="/blog"
        class="rounded-full px-3 py-1 text-sm border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 no-underline"
      >
        全部
      </a>
      {categories.map((cat) => (
        <a
          href={`/blog/category/${cat}`}
          class={`rounded-full px-3 py-1 text-sm border transition-colors duration-200 no-underline ${
            cat === category
              ? "border-[var(--color-accent)] text-[var(--color-accent)] bg-[var(--color-code-bg)]"
              : "border-[var(--color-border)] text-[var(--color-fg-muted)] hover:text-[var(--color-accent)]"
          }`}
        >
          {cat}
        </a>
      ))}
    </div>

    <!-- Tag filters -->
    <div class="flex flex-wrap gap-1.5 mb-10">
      {tags.map((t) => (
        <a
          href={`/blog/tag/${t}`}
          class="rounded-full px-2.5 py-0.5 text-xs border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 no-underline"
        >
          #{t}
        </a>
      ))}
    </div>

    <!-- Post list -->
    {posts.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-lg text-[var(--color-fg-muted)] mb-4">
          暂无 {category} 分类下的文章
        </p>
        <a
          href="/blog"
          class="text-sm text-[var(--color-accent)] hover:underline no-underline transition-colors duration-200"
        >
          &larr; 查看全部文章
        </a>
      </div>
    ) : (
      <div class="space-y-6">
        {posts.map((p) => {
          const slug = p.slug;
          const {
            title,
            date,
            category: cat,
            tags: ttags,
            summary,
          } = p.data;
          return (
            <article class="group border border-[var(--color-border)] rounded-xl p-5 bg-[var(--color-bg)] hover:shadow-md transition-shadow duration-200">
              <div class="flex items-center gap-3 mb-2">
                <time
                  datetime={date}
                  class="text-xs text-[var(--color-fg-muted)] font-mono"
                >
                  {date}
                </time>
                <a
                  href={`/blog/category/${cat}`}
                  class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-[var(--color-code-bg)] text-[var(--color-fg-muted)] border border-[var(--color-border)] no-underline hover:text-[var(--color-accent)] transition-colors duration-200"
                >
                  {cat}
                </a>
              </div>
              <a href={`/blog/${slug}`} class="no-underline">
                <h2 class="text-lg font-semibold text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-200 mb-2">
                  {title}
                </h2>
              </a>
              <p class="text-sm text-[var(--color-fg-muted)] mb-3 leading-relaxed">
                {truncate(summary)}
              </p>
              {ttags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {ttags.map((t: string) => (
                    <a
                      href={`/blog/tag/${t}`}
                      class="inline-block px-2 py-0.5 text-xs rounded-full bg-[var(--color-code-bg)] text-[var(--color-fg-muted)] border border-[var(--color-border)] no-underline hover:text-[var(--color-accent)] transition-colors duration-200"
                    >
                      #{t}
                    </a>
                  ))}
                </div>
              )}
              <div class="mt-3 pt-3 border-t border-[var(--color-border)]">
                <a
                  href={`/blog/${slug}`}
                  class="text-sm text-[var(--color-accent)] hover:underline no-underline transition-colors duration-200"
                >
                  阅读全文 &rarr;
                </a>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>
