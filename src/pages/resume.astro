---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Timeline from "../components/Timeline.astro";

// Resume data
const resumeEntries = await getCollection("resume");
const data = resumeEntries.length > 0 ? resumeEntries[0].data : null;

// Format period from YYYY-MM to readable Chinese
function formatPeriod(start: string, end: string): string {
  const fmt = (ym: string) => {
    const [y, m] = ym.split("-");
    return `${y}年${m}月`;
  };
  const startStr = fmt(start);
  const endStr = end === "至今" ? "至今" : fmt(end);
  return `${startStr} — ${endStr}`;
}

// Build work timeline items
const workItems = (data?.work ?? []).map((item) => ({
  title: item.role,
  subtitle: item.company,
  period: formatPeriod(item.start, item.end),
  description: item.description,
}));

// Build education timeline items
const educationItems = (data?.education ?? []).map((item) => ({
  title: `${item.degree} · ${item.major}`,
  subtitle: item.school,
  period: formatPeriod(item.start, item.end),
  description: "",
}));

const description = "个人简历 - 工作经历与教育背景";
---

<BaseLayout
  title="简历"
  description={description}
  currentPath="/resume"
>
  <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="lg:grid lg:grid-cols-[1fr_200px] lg:gap-12">
      <!-- Main Content -->
      <div>
        <!-- Page Header -->
        <div class="max-w-[68ch] mb-16">
          <h1 class="text-3xl font-bold text-[var(--color-fg)] mb-2">简历</h1>
          <p class="text-base text-[var(--color-fg-muted)]">
            工作经历与教育背景
          </p>
        </div>

        {!data ? (
          <p class="text-sm text-[var(--color-fg-muted)] py-12 text-center max-w-[68ch]">
            暂无简历数据
          </p>
        ) : (
          <div class="max-w-[68ch]">
            <!-- Work Experience -->
            {workItems.length > 0 && (
              <section class="mb-16">
                <h2 class="text-lg font-semibold text-[var(--color-fg)] mb-8">
                  工作经历
                </h2>
                <Timeline items={workItems} />
              </section>
            )}

            {/* Education */}
            {educationItems.length > 0 && (
              <section>
                <h2 class="text-lg font-semibold text-[var(--color-fg)] mb-8">
                  教育背景
                </h2>
                <Timeline items={educationItems} />
              </section>
            )}
          </div>
        )}
      </div>

      <!-- Sidebar: PDF Preview Button (desktop: sticky) -->
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <a
            id="preview-pdf-btn"
            href="/resume.pdf"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-fg)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors duration-200 cursor-pointer no-underline"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-4 h-4"
              aria-hidden="true"
            >
              <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
            <span data-pdf-label>在线预览简历</span>
          </a>
          <p id="pdf-status" class="mt-2 text-xs text-[var(--color-fg-muted)] hidden"></p>
        </div>
      </aside>
    </div>

    <!-- Mobile PDF button (visible <1024px) -->
    <div class="lg:hidden mt-12 text-center">
      <a
        id="preview-pdf-btn-mobile"
        href="/resume.pdf"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-fg)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors duration-200 cursor-pointer no-underline"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-4 h-4"
          aria-hidden="true"
        >
          <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
          <circle cx="12" cy="12" r="3" />
        </svg>
        <span data-pdf-label>在线预览简历</span>
      </a>
      <p id="pdf-status-mobile" class="mt-2 text-xs text-[var(--color-fg-muted)] hidden"></p>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    // Probe whether /resume.pdf exists; if not, gracefully degrade.
    fetch("/resume.pdf", { method: "HEAD" })
      .then((res) => {
        if (res.ok) return;
        document.querySelectorAll('a[id^="preview-pdf-btn"]').forEach((el) => {
          el.removeAttribute("href");
          el.removeAttribute("target");
          el.classList.add("pointer-events-none", "opacity-60");
          const label = el.querySelector("[data-pdf-label]");
          if (label) label.textContent = "简历准备中";
        });
        ["pdf-status", "pdf-status-mobile"].forEach((id) => {
          const status = document.getElementById(id);
          if (!status) return;
          status.classList.remove("hidden");
          status.textContent = "PDF 简历正在准备，可稍后再回";
        });
      })
      .catch(() => {});
  })();
</script>
