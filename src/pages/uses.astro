---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Uses data
const usesEntries = await getCollection("uses");
const data = usesEntries.length > 0 ? usesEntries[0].data : null;

// Filter out empty groups (no items)
const groups = (data?.groups ?? []).filter(
  (g: any) => g.items && g.items.length > 0
);

const description = "我使用的硬件、软件、工具和资源";
---

<BaseLayout
  title="Uses"
  description={description}
  currentPath="/uses"
>
  <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="max-w-[68ch] mx-auto">
      <!-- Page Header -->
      <div class="mb-16">
        <h1 class="text-3xl font-bold text-[var(--color-fg)] mb-2">Uses</h1>
        <p class="text-base text-[var(--color-fg-muted)]">
          我日常使用的硬件、软件、工具和资源
        </p>
      </div>

      {groups.length === 0 ? (
        <p class="text-sm text-[var(--color-fg-muted)] py-12 text-center">
          暂无内容
        </p>
      ) : (
        <div class="flex flex-col gap-12">
          {groups.map((group: any) => (
            <section>
              <h2 class="text-lg font-semibold text-[var(--color-fg)] mb-5">
                {group.category}
              </h2>
              <ul class="flex flex-col gap-4 list-none p-0 m-0">
                {group.items.map((item: any) => (
                  <li class="flex flex-col gap-0.5">
                    <div class="flex items-center gap-2">
                      {item.url ? (
                        <a
                          href={item.url}
                          target="_blank"
                          rel="noopener"
                          class="text-sm font-medium text-[var(--color-fg)] hover:text-[var(--color-accent)] no-underline transition-colors duration-200"
                        >
                          {item.name}
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 16 16"
                            fill="currentColor"
                            class="w-3 h-3 inline-block ml-1 -mt-0.5"
                            aria-hidden="true"
                          >
                            <path d="M6.22 8.72a.75.75 0 0 0 1.06 1.06l5.22-5.22v1.69a.75.75 0 0 0 1.5 0v-3.5a.75.75 0 0 0-.75-.75h-3.5a.75.75 0 0 0 0 1.5h1.69L6.22 8.72Z" />
                            <path d="M3.5 6.75c0-.69.56-1.25 1.25-1.25H7A.75.75 0 0 0 7 4H4.75A2.75 2.75 0 0 0 2 6.75v4.5A2.75 2.75 0 0 0 4.75 14h4.5A2.75 2.75 0 0 0 12 11.25V9a.75.75 0 0 0-1.5 0v2.25c0 .69-.56 1.25-1.25 1.25h-4.5c-.69 0-1.25-.56-1.25-1.25v-4.5Z" />
                          </svg>
                        </a>
                      ) : (
                        <span class="text-sm font-medium text-[var(--color-fg)]">
                          {item.name}
                        </span>
                      )}
                    </div>
                    <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
                      {item.note}
                    </p>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>
